		(uuid "ad85949b-6164-54fa-88e4-eb9e310d5ed1")
	)
	(text "2. If BU01 is configured for UART, replace SPI nets with TX/RX nets before firmware bring-up."
		(exclude_from_sim no)
		(at 28.702 261.62 0)
