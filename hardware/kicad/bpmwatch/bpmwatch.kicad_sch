	(text "BPMWATCH module-level schematic. One master node plus one slave node repeated for Slave 1 and Slave 2."
		(exclude_from_sim no)
		(at 211.24 30.27 0)
		(effects
			(font
				(size 1.7 1.7)
			)
			(justify left)
		)
		(uuid "21ec13a0-4b01-50b7-a669-fbc6262f3ca2")
	)
	(text "1. Use 3.3V-compatible logic for BU01, ST7789, MAX30102, and LSM303DLHC."
		(exclude_from_sim no)
		(at 28.702 255.62 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "3103f088-87ef-580a-9ca3-35220473618d")
	)
	(text "BU01 mode/pinout and final ESP32 dev-board pin mapping must be confirmed before PCB layout."
		(exclude_from_sim no)
